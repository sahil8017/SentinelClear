# ── Database ──
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=sentinelclear
DATABASE_URL=postgresql+asyncpg://sentinel:your_secure_postgres_password@postgres-db:5432/sentinelclear

# ── RabbitMQ ──
RABBITMQ_DEFAULT_USER=sentinel
RABBITMQ_DEFAULT_PASS=your_secure_rabbitmq_password
RABBITMQ_URL=amqp://sentinel:your_secure_rabbitmq_password@rabbitmq:5672/

# ── JWT ──
JWT_SECRET_KEY=generate_a_secure_random_string_for_jwt_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Fraud Detection — Rule Engine (all optional, sensible defaults) ──
FRAUD_AMOUNT_THRESHOLD=50000
FRAUD_VELOCITY_MAX=5
FRAUD_VELOCITY_WINDOW=600
FRAUD_DAILY_VOLUME_LIMIT=200000
FRAUD_NEW_ACCOUNT_HOURS=24
FRAUD_NEW_ACCOUNT_AMOUNT=10000
FRAUD_REVIEW_THRESHOLD=0.4
FRAUD_BLOCK_THRESHOLD=0.7

# ── Reconciliation ──
RECONCILIATION_INTERVAL_HOURS=24

# ── Grafana ──
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=your_secure_grafana_password
